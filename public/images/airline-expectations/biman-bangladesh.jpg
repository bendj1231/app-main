		<style id="wp-custom-css">
			.bbpress-recent-reply-li.new{
	list-style-type: none;
	background: url('/wp-content/uploads/2022/06/yellow-arrow.svg') no-repeat 1px;
	padding-left: 20px;
	padding-bottom: 15px;
	background-size: 45px;
}

.bbpress-recent-reply-li{
	list-style-type: none;
	background: url('/wp-content/uploads/2022/06/blue-arrow.svg') no-repeat 1px;
	padding-left: 20px;
	padding-bottom: 15px;
	background-size: 45px;
}

.wpv-loop.js-wpv-loop li {
	list-style-type: none;
	background: url('/wp-content/uploads/2022/06/blue-arrow.svg') no-repeat 1px;
	padding-left: 20px!important;
	padding: 14px 0px 2px 5px;
	margin-top: -20px;
	background-size: 45px;
}

.filter-wrapper .filters .cat-select .cat-name:after {
    content: "";
    width: 13px;
    height: 8px;
    background-image: url('/wp-content/uploads/2023/01/filter-arrow.svg');
    background-position: 50%;
    background-size: cover;
    background-repeat: repeat;
    position: absolute;
    right: 1rem;
    top: 50%;
    -webkit-transform: translateY(-50%);
    -ms-transform: translateY(-50%);
    transform: translateY(-50%);
}


.nav-previous, .nav-next {
	width: unset;
}

.bbp-pagination-links {
	margin: 20px 0;
}

a.favorite-toggle {
	    background-color: rgba( 0, 56, 118, 1 )!important;
    border: 2px solid rgba( 0, 56, 118, 1 )!important;
    font-weight: bold!important;
    color: var(--base-3)!important;
    border-radius: 0.3em!important;
    padding: 5px 20px!important;
    transition: all 0.3s ease;
	display: inline-block;
}

a.favorite-toggle:hover {
	 background-color: rgba( 255, 255, 255, 1 )!important;
    border: 2px solid rgba( 0, 56, 118, 1 )!important;
    font-weight: bold!important;
    color: rgba( 0, 56, 118, 1 )!important;
    border-radius: 0.3em!important;
    text-decoration: none;
    cursor: pointer;
}
    transition: all 0.3s ease;
	display: inline-block;
}

@media screen and (max-width: 420px) {
	.single-adb_photo .wp-block-table td, .wp-block-table th {
		display: block;
	}
	
	.single-adb_photo table, th, td {
	border: 0;
	}
	
	.single-adb_photo td {
	border: 0;
		padding: 1px 10px!important;
	}
	
.adb_photo-template-default.single.single-adb_photo	#content {
		padding: 15px 0!important;
	}
}

.adb_photo .wp-block-table h2 {
    margin-top: 50px;
}

/* Buddy Press Updates */
#buddypress.buddypress-wrap .bp-navs ul.bp-priority-object-nav-nav-items {
	display: flex;
	flex-direction: column;
}

#members-list {
	list-style: none;
	margin-left: 10px;
}

#members-list li {
	padding-bottom: 10px;
	margin-bottom: 25px;
	border-bottom: 1px solid #ccc;
}


/* New Home Page */

.cafe-main-container {
	max-width: 1440px;
	margin: 0 auto;
}
.wp-block-button a {
	border-radius: 10px;
}

.wp-block-button a:after {
	content: " →";
}

.latest-posts-list h2 a {
    background: url(/wp-content/uploads/2022/06/blue-arrow.svg) no-repeat 1px;
    padding-left: 20px !important;
    padding: 0px 0px 15px 5px;
 
    background-size: 40px;
}
.gb-query-loop-item.gallery.type-gallery.status-publish {
	margin-bottom:0px!important;
}

.gallery-pagination .gb-block-is-current,
.gallery-pagination .dots {
	padding: 7px 20px;
}

.post-type-archive-gallery #nav-below {display: none;}

span.button.js-wpv-fields-and-views-in-toolbar,
span.button.js-cred-in-toolbar,span.button.js-wpcf-access-editor-button {
	display: none;
}

/* Gallery page bottom */
.single-gallery .tb-fields-and-text h3 {
	margin-bottom: 25px;
}
.single-gallery .tb-image img {
		padding: 15px;
    border-top: 1px solid var(--acafe-light-blue);
    border-right: 1px solid var(--acafe-light-blue);
    border-bottom: 3px solid var(--acafe-light-blue);
    border-left: 1px solid var(--acafe-light-blue);
    background-color: #fafafa;
}		</style>
